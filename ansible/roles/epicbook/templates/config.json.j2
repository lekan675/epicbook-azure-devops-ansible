{
  "development": {
    "username": "{{ db_user }}",
    "password": "{{ db_password }}",
    "database": "{{ db_name }}",
    "host": "{{ db_host }}",
    "port": 3306,
    "dialect": "mysql",
    "dialectOptions": {
      "ssl": {
        "require": true,
        "rejectUnauthorized": false
      }
    }
  },
  "production": {
    "username": "{{ db_user }}",
    "password": "{{ db_password }}",
    "database": "{{ db_name }}",
    "host": "{{ db_host }}",
    "port": 3306,
    "dialect": "mysql",
    "dialectOptions": {
      "ssl": {
        "require": true,
        "rejectUnauthorized": false
      }
    }
  }
}
